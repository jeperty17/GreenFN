# GreenFN backend environment variables
# Copy this file to `.env` and replace placeholders with real values.

PORT=3000
NODE_ENV=development

# Prisma pooled connection URL (recommended for app runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma direct connection URL (recommended for migrations)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# AI provider and model selection (backend only)
AI_PROVIDER="openai"
AI_PRIMARY_MODEL="gpt-4.1-mini"
AI_FALLBACK_MODEL="gpt-4.1-nano"

# AI secret key (backend only; never expose to frontend)
OPENAI_API_KEY=""

# CORS allowlist for browser origins (comma-separated)
CORS_ALLOWED_ORIGINS="http://localhost:5173,https://greenfn-web.vercel.app"
