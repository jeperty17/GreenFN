# GreenFN backend environment variables
# Copy this file to `.env` and replace placeholders with real values.

PORT=3000
NODE_ENV=development

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# AI provider and model selection (backend only)
AI_PROVIDER="openai"
AI_PRIMARY_MODEL="gpt-4.1-mini"
AI_FALLBACK_MODEL="gpt-4.1-nano"
AI_TIMEOUT_MS=12000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=20

# AI secret key (backend only; never expose to frontend)
OPENAI_API_KEY=""

# CORS allowlist for browser origins (comma-separated)
CORS_ALLOWED_ORIGINS="http://localhost:5173,https://greenfn-web.vercel.app"
